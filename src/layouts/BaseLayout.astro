---
import { Footer } from '@/components/Footer'
import { Header } from '@/components/Header'
import '@/styles/tailwind.css'

interface Props {
  title?: string
  description?: string
}

const defaultTitle = '코드싸이 - 엔지니어링을 즐겁게'
const defaultDescription =
  '코드싸이의 블로그. 엔지니어링을 즐겁게 생각합니다. 세상에 대해 공부하고 알아간 것을 자유롭게 기록하고 정리합니다.'

const { title, description = defaultDescription } = Astro.props
const pageTitle = title ? `${title} : 코드싸이 블로그` : defaultTitle
const site = Astro.site ?? new URL('https://codepsy2001.blog')
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/'
---

<!doctype html>
<html lang="ko" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />
    <link
      rel="alternate"
      type="application/rss+xml"
      href={new URL('/feed.xml', site)}
    />
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('theme')
          const prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)',
          ).matches
          document.documentElement.classList.toggle(
            'dark',
            theme === 'dark' || (!theme && prefersDark),
          )
        } catch {}
      })()
    </script>
  </head>
  <body class="flex h-full bg-zinc-50 dark:bg-black">
    <div class="flex w-full">
      <div class="fixed inset-0 flex justify-center sm:px-8">
        <div class="flex w-full max-w-7xl lg:px-8">
          <div
            class="w-full bg-white ring-1 ring-zinc-100 dark:bg-zinc-900 dark:ring-zinc-300/20"
          >
          </div>
        </div>
      </div>
      <div class="relative flex w-full flex-col">
        <Header pathname={pathname} client:load />
        <main class="flex-auto">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
